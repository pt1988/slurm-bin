#!/usr/bin/env bash
set -e

FORMAT="notebook"
INPLACE=""
PARTITION="gpu"
TIME="02:00:00"
CPUS=4
MEM=16G
GRES="gpu:1"

# Parse simple options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --format)
      FORMAT="$2"; shift 2 ;;
    --inplace)
      INPLACE="--inplace"; shift 1 ;;
    --partition)
      PARTITION="$2"; shift 2 ;;
    --time)
      TIME="$2"; shift 2 ;;
    --cpus)
      CPUS="$2"; shift 2 ;;
    --mem)
      MEM="$2"; shift 2 ;;
    --gres)
      GRES="$2"; shift 2 ;;
    -*)
      echo "Unknown option: $1"; exit 1 ;;
    *)
      break ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "Usage: slurm-nb-run [options] notebook1.ipynb [notebook2.ipynb ...]"
  exit 1
fi

NOTEBOOKS=("$@")

sbatch <<EOF
#!/bin/bash

###SBATCH --partition fullq
#SBATCH --partition gpuq
#SBATCH --gres=gpu:1
#SBATCH --mem-per-cpu 40G
#SBATCH --time 1-0:00:00
#SBATCH --job-name jupyter-nbconvert
#SBATCH --output log/%J.log

###SBATCH --account gf_g6817550025
#SBATCH --account g_g6817550025

# get tunneling info
XDG_RUNTIME_DIR=""
port=$(shuf -i8000-9999 -n1)
node=$(hostname -s)
user=$(whoami)
cluster="br1.paas.ku.ac.th"

module load anaconda          # adapt to your cluster
source activate pt        # or 'conda activate my_env'

for nb in "${NOTEBOOKS[@]}"; do
  ## cd "\$(dirname "\$nb")"
  base=\$( "\$nb")
  echo "\$nb"
  echo "python3.13 /home/g6817550025/.conda/envs/pt/bin/jupyter nbconvert  --to ${FORMAT}  --execute \"\$nb\"  ${INPLACE}"
  python3.13 /home/g6817550025/.conda/envs/pt/bin/jupyter nbconvert  --to ${FORMAT} --allow-errors  --execute "\$nb"  ${INPLACE}
done
EOF

